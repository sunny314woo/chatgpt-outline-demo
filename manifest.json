{
  "manifest_version": 3,
  "name": "ChatGPT Outline (Demo)",
  "version": "1.0.0",
  "description": "A source-available demo build for navigating long ChatGPT conversations with a local outline.",

  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon_16.png",
      "24": "icons/icon_24.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png"
    },
    "default_title": "ChatGPT Outline (Demo)"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chatgpt.openai.com/*",
        "https://chat.openai.com/*"
      ],
      "css": [
        "sidebar/sidebar.css"
      ],
      "js": [
        "directory-engine.js",
        "navigation.js",
        "sidebar/sidebar.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
